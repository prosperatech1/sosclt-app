--- app.json (原始)


+++ app.json (修改后)
{
  "expo": {
    "name": "SOSCLT",
    "slug": "sosclt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF0000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sosclt.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Este app precisa acessar o microfone para gravar áudio em situações de emergência.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF0000"
      },
      "package": "com.sosclt.app",
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Este app precisa acessar o microfone para gravar áudio em situações de emergência."
        }
      ],
      [
        "expo-background-fetch",
        {
          "backgroundTaskIdentifier": "com.sosclt.backgroundRecording"
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "YOUR_SUPABASE_URL",
      "supabaseAnonKey": "YOUR_SUPABASE_ANON_KEY"
    }
  }
}
