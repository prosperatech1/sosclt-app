{
  "expo": {
    "name": "SOSCLT",
    "slug": "sosclt",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sosclt.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Este app precisa acessar o microfone para gravar áudio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.sosclt.app",
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": ""
    },
    "extra": {
      "eas": {
        "projectId": "76730309-61c1-4dda-b6c1-eb3812b5f1ee"
      }
    }
  }
}
