--- android/app/src/main/res/layout/sos_widget.xml (原始)


+++ android/app/src/main/res/layout/sos_widget.xml (修改后)
<?xml version="1.0" encoding="utf-8"?>
<!-- Layout do Widget SOS para Android -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Botão SOS -->
    <Button
        android:id="@+id/widget_sos_button"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/sos_button_background"
        android:text="🆘"
        android:textSize="32sp"
        android:contentDescription="Acionar SOS" />

    <!-- Texto explicativo -->
    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SOS"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

</LinearLayout>
